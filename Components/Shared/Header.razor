@using Microsoft.AspNetCore.Identity
@using Campus_Cart_Student_Marketplace.Models
@inject HttpClient Http
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<header class="header">

    <!-- LEFT: LOGO + MOBILE MENU -->
    <div class="header__logo__menu">

        <button class="mobile-menu-btn" @onclick="ToggleMenu">
            ☰
        </button>

        <NavLink class="header__logo" href="/">
            <img src="/img/logo-2.webp" alt="Campus Cart Logo" />
        </NavLink>
    </div>

    <!-- CENTER: SEARCH -->
    <div class="header__search">
        <SearchBar />
    </div>

    <!-- RIGHT: AUTH + CART -->
    <div class="desktop-actions">

        @if (IsLoggedIn)
        {
            <!-- USER MENU -->
            <div class="user-menu">

                <button class="icon-btn user-btn" @onclick="ToggleMenu">
                    <img src="/img/user-icon.webp" alt="User" />
                    <span>@UserName</span>
                    <span class="arrow">▼</span>
                </button>

                @if (ShowUserMenu)
                {
                    <div class="dropdown-menu">

                        <NavLink href="/dashboard">My Profile</NavLink>
                        <NavLink href="/my-listings">My Listings</NavLink>

                        <hr />

                        <button @onclick="Logout">
                            Logout
                        </button>

                    </div>
                }

            </div>

            <!-- CART -->
            <button class="icon-btn" @onclick="NavigateToCart">
                <img src="/img/cart-icon.webp" alt="Cart" />
            </button>
        }
        else
        {
            <!-- NOT LOGGED IN -->
            <button class="btn btn-outline-primary me-2"
                    @onclick="GoToLogin">
                Login
            </button>

            <button class="btn btn-primary"
                    @onclick="GoToRegister">
                Register
            </button>
        }

    </div>

</header>

<!-- MOBILE MENU -->
@if (ShowMobileMenu)
{
    <div class="mobile-menu-overlay" @onclick="CloseMenu">

        <div class="mobile-menu" @onclick:stopPropagation="true">

            <div class="mobile-menu-header">
                <h3>Menu</h3>

                <button class="close-btn" @onclick="CloseMenu">
                    ✕
                </button>
            </div>

            <NavLink href="/">Home</NavLink>

            @if (IsLoggedIn)
            {
                <NavLink href="/dashboard">Profile</NavLink>
                <NavLink href="/cart">Cart</NavLink>
                <NavLink href="/sell">Sell Item</NavLink>

                <button @onclick="Logout">
                    Logout
                </button>
            }
            else
            {
                <NavLink href="/login">Login</NavLink>
                <NavLink href="/register">Register</NavLink>
            }

        </div>

    </div>
}

@code {

    private bool ShowMobileMenu;
    private bool ShowUserMenu = true;

    private bool IsLoggedIn;
    private string UserName = "User";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        IsLoggedIn = user.Identity?.IsAuthenticated ?? false;

        if (IsLoggedIn)
        {
            var appUser = await UserManager.GetUserAsync(user);
            UserName = appUser?.UserName ?? "User";
        }
    }

    private void ToggleMenu()
    {
        ShowMobileMenu = !ShowMobileMenu;
    }

    private void CloseMenu()
    {
        ShowMobileMenu = false;
        ShowUserMenu = false;
    }

    private void ToggleUserMenu()
    {
        ShowUserMenu = !ShowUserMenu;
    }

    private void NavigateToCart()
    {
        Nav.NavigateTo("/cart");
    }

    private void GoToLogin()
    {
        Nav.NavigateTo("/login");
    }

    private void GoToRegister()
    {
        Nav.NavigateTo("/register");
    }

    private async Task Logout()
    {
        await Http.PostAsync("api/logout", null);

        Nav.NavigateTo("/login", forceLoad: true);
    }
}