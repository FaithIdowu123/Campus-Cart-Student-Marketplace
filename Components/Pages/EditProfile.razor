@page "/profile/edit/"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Campus_Cart_Student_Marketplace.Models
@inject Campus_Cart_Student_Marketplace.Services.ApplicationUserService UserService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>Edit Profile</PageTitle>

<div class="form-page">

    <div class="form-card">

        <h1>Edit Profile</h1>

        <EditForm Model="User" OnValidSubmit="EditUserProfile">

            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label>Full Name</label>
                <InputText @bind-Value="User.FullName" />
            </div>

            <div class="form-group">
                <label>Username</label>
                <InputText @bind-Value="User.UserName" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <InputText @bind-Value="User.Email" />
            </div>


            <div class="form-group">
                <label>Address</label>
                <InputTextArea @bind-Value="User.Address" />
            </div>

            <button type="submit" class="primary-btn">
                Save Profile
            </button>

            <button type="button" class="secondary-btn" @onclick="NavigateToDashboard">
                Cancel
            </button>

        </EditForm>

    </div>

</div>

@code {
    [SupplyParameterFromQuery]
    public string? userid { get; set; }

    private ApplicationUser User = new();

    protected override async Task OnInitializedAsync()
    {
        var authState =
            await AuthStateProvider.GetAuthenticationStateAsync();

        Console.WriteLine(
            $"Authenticated: {authState.User.Identity?.IsAuthenticated}");

        var user =
            await UserManager.GetUserAsync(authState.User);


        if (user == null)
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        User = user;
    }

    private async Task EditUserProfile()
    {
        await UserService.UpdateUser(User);
        Nav.NavigateTo("/dashboard");
    }

    private void NavigateToDashboard()
    {
        Nav.NavigateTo("/dashboard");
    }
}