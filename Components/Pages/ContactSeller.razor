@page "/contact-seller/{ItemId:int}"
@using Campus_Cart_Student_Marketplace.Models
@inject Campus_Cart_Student_Marketplace.Services.MessageService MessageService 
@inject Campus_Cart_Student_Marketplace.Services.ItemService ItemService
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@inject Campus_Cart_Student_Marketplace.Services.ApplicationUserService UserService 
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="container my-5" style="max-width: 600px;">
    <div class="card p-4 shadow-sm border-0 rounded">
        <h3 class="mb-3 text-primary"><i class="bi bi-envelope"></i> Contact Seller</h3>
        <p class="text-muted small">Inquire about availability, state of the item, or arrange a safe meet-up point on
            campus.</p>
            <hr />

            <EditForm Model="messageModel" OnValidSubmit="HandleSend">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label class="form-label fw-bold">Your Message</label>
                    <InputTextArea class="form-control" rows="5"
                                   placeholder="Hi! Is this item still available? I can meet near the library..."
                                   @bind-Value="messageModel.Content" />
                    <ValidationMessage For="@(() => messageModel.Content)" class="text-danger small mt-1" />
                </div>

                @if (isSuccess)
                {
                    <div class="alert alert-success py-2">
                        Message sent successfully! The seller will view this on their dashboard.
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Send Message</button>
                    <button type="button" class="btn btn-light" @onclick="GoBack">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>

@code {
    [Parameter] public int ItemId { get; set; }
    [Parameter] public string ReceiverId { get; set; } = string.Empty;

    private Campus_Cart_Student_Marketplace.Models.Message messageModel = new();
    private bool isSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        var authState =
            await AuthStateProvider
                .GetAuthenticationStateAsync();

        var CurrentUser =
            await UserManager.GetUserAsync(
                authState.User);

        if (CurrentUser == null)
        {
            Nav.NavigateTo("/login", true);
            return;
        }
        var item = await ItemService.GetItemByIdAsync(ItemId);

        if (item == null) return;

        messageModel.ItemId = ItemId;

        // seller receives message
        messageModel.ReceiverUserId = item.SellerId;

        // sender should be current logged-in user (placeholder for now)
        messageModel.SenderUserId = CurrentUser.Id;
    }

    private async Task HandleSend()
    {
        var sent = await MessageService.SendMessage(messageModel);

        if (sent)
        {
            isSuccess = true;
            messageModel.Content = "";
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo($"/item/{ItemId}");
    }
}