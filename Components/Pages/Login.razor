@page "/login"

<PageTitle>Login</PageTitle>


<div class="auth-container">

    <div class="auth-card">

        <h1>Login</h1>

        <form method="post" action="/api/login">

            <div class="form-group">
                <label>Email</label>
                <input
                    name="Email"
                    type="email"
                    class="form-control" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input
                    name="Password"
                    type="password"
                    class="form-control" />
            </div>

            <button
                type="submit"
                class="primary-btn">
                Login
            </button>

        </form>

    </div>

</div>
