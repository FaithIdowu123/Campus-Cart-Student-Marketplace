@page "/cart"

@using Campus_Cart_Student_Marketplace.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity

@inject Campus_Cart_Student_Marketplace.Services.ApplicationUserService UserService 
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject Campus_Cart_Student_Marketplace.Services.CartService CartService
@inject NavigationManager Nav
<PageTitle>Cart</PageTitle>
<div class="cart-container">
    <h2 class="cart-title"><i class="bi bi-cart3"></i> Your Campus Cart</h2>

    @if (cartItems == null || !cartItems.Any())
    {
        <div class="empty-cart">
            <h4>Your cart is empty!</h4>
            <p>Find amazing student deals on textbooks, furniture, and more.</p>
            <a href="/marketplace" class="btn-primary">Browse Marketplace</a>
        </div>
    }
    else
    {
        <div class="cart-layout">

            <!-- LEFT SIDE: ITEMS -->
            <div class="cart-items">
                @foreach (var item in cartItems)
                {
                    <div class="cart-card">
                        <img src="@(item.Item?.ImageUrl ?? "images/placeholder.png")" />

                        <div class="cart-info">
                            <h5>@item.Item?.Title</h5>
                            <p class="price">$@item.Item?.Price</p>
                        </div>

                        <input type="number"
                               value="@item.Quantity"
                               min="1"
                               class="qty-input"
                               @onchange="@(e => UpdateQty(item, int.Parse(e.Value?.ToString())))" />

                        <button class="remove-btn" @onclick="() => RemoveItem(item.Id)">
                            Remove
                        </button>
                    </div>
                }
            </div>

            <!-- RIGHT SIDE: SUMMARY -->
            <div class="cart-summary">
                <h4>Order Summary</h4>
                <hr />

                <div class="total">
                    <span>Total:</span>
                    <span class="total-price">
                        $@CartService.GetTotal(currentUserId)
                    </span>
                </div>

                <div class="warning">
                    ⚠️ Campus Cart does not process payments online.
                    Arrange secure exchange on campus.
                </div>

                <button class="checkout-btn" disabled>
                    Proceed to Secure Checkout
                </button>
            </div>

        </div>
    }
</div>

@code {
    private List<CartItem> cartItems = new();
    private ApplicationUser? CurrentUser;
    private string currentUserId = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        CurrentUser = await UserManager.GetUserAsync(authState.User);

        if (CurrentUser == null)
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        currentUserId = CurrentUser.Id;
        LoadCart();
    }

    private async Task UpdateQty(CartItem cartItem, int qty)
    {
        cartItem.Quantity = qty;

        var success = await CartService.UpdateQuantity(cartItem);

        if (success)
        {
            Nav.NavigateTo(Nav.Uri, forceLoad: true);
        }
    }

    private void LoadCart()
    {
        cartItems = CartService.GetCartItems(currentUserId);
    }

    private void RemoveItem(int cartItemId)
    {
        CartService.RemoveFromCart(cartItemId);
        LoadCart();
    }
}