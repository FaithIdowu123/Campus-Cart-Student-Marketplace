@page "/register"

<PageTitle>Register</PageTitle>

<div class="auth-container">

    <div class="auth-card">

        <h1>Create Account</h1>

        <form method="post" action="/api/register">

            <div class="form-group">
                <label>Full Name</label>
                <input
                    name="FullName"
                    class="form-control" />
            </div>

            <div class="form-group">
                <label>Username</label>
                <input
                    name="UserName"
                    class="form-control" />
            </div>

            <div class="form-group">
                <label>Address</label>
                <input
                    name="Address"
                    class="form-control" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <input
                    name="Email"
                    type="email"
                    class="form-control" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input
                    name="Password"
                    type="password"
                    class="form-control" />
            </div>

            <div class="form-group">
                <label>Confirm Password</label>
                <input
                    name="ConfirmPassword"
                    type="password"
                    class="form-control" />
            </div>

            <button
                type="submit"
                class="primary-btn">
                Register
            </button>

        </form>

    </div>

</div>
