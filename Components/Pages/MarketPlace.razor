@page "/marketplace"
@using Microsoft.AspNetCore.Components
@inject NavigationManager Nav
@rendermode InteractiveServer
@using Campus_Cart_Student_Marketplace.Components.Shared
@inject Campus_Cart_Student_Marketplace.Services.ItemService ItemService
@inject Campus_Cart_Student_Marketplace.Services.CategoryService CategoryService
@using Campus_Cart_Student_Marketplace.Models

<PageTitle>Campus Cart - MarketPlace</PageTitle>

<div class="main">

    <button class="filter-toggle" @onclick="OpenFilters">
        ☰ Filters
    </button>

    <div class="market">

        <!-- Desktop Sidebar -->
        <aside class="market-side">
            <h3>Categories</h3>

            <div class="category-list">
                @foreach(var category in Categories){
                   <label>
                        <input type="checkbox"
                            checked="@SelectedCategories.Contains(category.Id)"
                            @onchange="(e) => ToggleCategory(category.Id)" />

                        @category.Name
                        (@GetCategoryCount(category.Id))
                    </label>
                }  
            </div>

            <div class="price-filter">
                <label>
                    Maximum Price: <strong>₦@MaxPrice</strong>
                </label>

                <input type="range"
                    min="0"
                    max="500000"
                    step="1000"
                    value="@MaxPrice"
                    @oninput="UpdatePrice" />
            </div>
        </aside>

        <!-- Products -->
        <section class="market-main">
            @if (loading)
            {
                @for (int i = 0; i < 12; i++)
                {
                    <Loading Text="Loading marketplace items..." />
                }
            }
            else
            {
                @foreach (var item in items)
                {
                    <ItemComponent @key="item.Id" Item="item" />
                }
            }
        </section>

    </div>
</div>

@if (ShowFilters)
{
    <div class="filter-overlay" @onclick="CloseFilters">

        <div class="filter-modal" @onclick:stopPropagation="true">

            <button class="close-btn" @onclick="CloseFilters">
                ✕
            </button>

            <h3>Categories</h3>

            <div class="category-list">
                @foreach(var category in Categories){
                    <label>
                        <input type="checkbox"
                            checked="@SelectedCategories.Contains(category.Id)"
                            @onchange="(e) => ToggleCategory(category.Id)" />

                        @category.Name
                        (@GetCategoryCount(category.Id))
                    </label>
                }  
            </div>

            <div class="price-filter">
                <label>
                    Maximum Price: <strong>₦@MaxPrice</strong>
                </label>

                <input type="range"
                    min="0"
                    max="500000"
                    step="1000"
                    value="@MaxPrice"
                    @oninput="UpdatePrice" />
            </div>

        </div>

    </div>
}

@code {
    [SupplyParameterFromQuery]
    public string? Search { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public int? Category { get; set; }

    private HashSet<int> SelectedCategories = new();

    private int MaxPrice = 50000;

    private bool ShowFilters = false;

    private bool loading = true;

    private List<Item> Items = [];
    private List<Item> items = [];
    private List<Category> Categories = [];

    protected override async Task OnInitializedAsync()
    {
        loading = true;

        // Load from services (single source of truth)
        Items = ItemService.GetItems();
        Categories = CategoryService.GetCategories();

        loading = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        loading = true;

        // Sync URL category → selected filters
        SelectedCategories.Clear();

        if (Category is not null)
        {
            SelectedCategories.Add(Category.Value);
        }

        await FilterItems(Search);
    }

    private async Task FilterItems(string? search)
    {
        loading = true;

        IEnumerable<Item> query = Items;

        // Use ItemService logic (centralized search behavior)
        if (!string.IsNullOrWhiteSpace(search))
        {
            query = ItemService.SearchItems(search);
        }

        // Category filter (still local UI state)
        if (SelectedCategories.Any())
        {
            query = query.Where(item =>
                SelectedCategories.Contains(item.CategoryId));
        }

        // Price filter
        query = query.Where(item =>
            item.Price <= MaxPrice);

        items = query.ToList();

        loading = false;

        await InvokeAsync(StateHasChanged);
    }

    private void OpenFilters()
    {
        ShowFilters = true;
    }

    private void CloseFilters()
    {
        ShowFilters = false;
    }

    private async Task ToggleCategory(int categoryId)
    {
        if (SelectedCategories.Contains(categoryId))
        {
            SelectedCategories.Remove(categoryId);
        }
        else
        {
            SelectedCategories.Add(categoryId);
        }

        await FilterItems(Search);
    }

    private async Task UpdatePrice(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int value))
        {
            MaxPrice = value;
        }

        await FilterItems(Search);
    }

    private int GetCategoryCount(int categoryId)
    {
        return Items.Count(i => i.CategoryId == categoryId);
    }
}