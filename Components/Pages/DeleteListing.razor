@page "/listings/delete/{Id:int}"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Campus_Cart_Student_Marketplace.Models
@inject Campus_Cart_Student_Marketplace.Services.ItemService ItemService
@inject Campus_Cart_Student_Marketplace.Services.CartService CartService
@inject Campus_Cart_Student_Marketplace.Services.ApplicationUserService UserService  
@inject NavigationManager Nav
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Delete Listing</PageTitle>

<div class="confirm-page">

    <div class="confirm-card">

        <h1>Delete Listing</h1>

        <p>
            Are you sure you want to delete this listing?
        </p>

        <div class="actions">

            <button class="danger-btn" @onclick="DeleteListings">
                Delete Listing
            </button>

            <button class="secondary-btn" @onclick="NavigateToDashboard">
                Cancel
            </button>

        </div>

    </div>

</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Item? Item;
    private ApplicationUser? User;

    protected override async Task OnInitializedAsync()
    {
        Item = await ItemService.GetItemByIdAsync(Id);

        var authState =
            await AuthStateProvider.GetAuthenticationStateAsync();

        Console.WriteLine(
            $"Authenticated: {authState.User.Identity?.IsAuthenticated}");

        var user =
            await UserManager.GetUserAsync(authState.User);


        if (user == null)
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        User = user;
    }

    private async Task DeleteListings()
    {
        var deleted = await ItemService.DeleteItemAsync(Id);
        User.Listings.Remove(Id);
        await UserService.UpdateUser(User);
        var cartitems = await CartService.GetCartItemAsync(Id);

        foreach (var I in cartitems){
            await CartService.RemoveFromCart(I.Id);
        }
        

        if (deleted)
        {
            Nav.NavigateTo("/dashboard");
        }
    }

    private void NavigateToDashboard()
    {
        Nav.NavigateTo("/dashboard");
    }
}