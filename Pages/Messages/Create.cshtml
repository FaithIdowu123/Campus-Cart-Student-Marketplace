@page
@model Campus_Cart_Student_Marketplace.Pages_Messages.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>Message</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Message.ItemId" class="control-label"></label>
                <select asp-for="Message.ItemId" class ="form-control" asp-items="ViewBag.ItemId" aria-required="true"></select>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Message.SenderUserId" class="control-label"></label>
                <input asp-for="Message.SenderUserId" class="form-control" aria-required="true"/>
                <span asp-validation-for="Message.SenderUserId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Message.ReceiverUserId" class="control-label"></label>
                <input asp-for="Message.ReceiverUserId" class="form-control" aria-required="true"/>
                <span asp-validation-for="Message.ReceiverUserId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Message.Content" class="control-label"></label>
                <input asp-for="Message.Content" class="form-control" aria-required="true"/>
                <span asp-validation-for="Message.Content" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Message.Timestamp" class="control-label"></label>
                <input asp-for="Message.Timestamp" class="form-control" />
                <span asp-validation-for="Message.Timestamp" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Message.IsRead" /> @Html.DisplayNameFor(model => model.Message.IsRead)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
